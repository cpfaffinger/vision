# =============================================================================
#  Vision API – Environment Configuration
#  Profile: DEVELOPMENT  (local machine, hot-reload, verbose logging)
#
#  Goal: dev behaviour mirrors production as closely as possible so bugs
#  surface early. Use the same model + detector as the high-end profile.
# =============================================================================

# ─── Face Recognition Model ───────────────────────────────────────────────────
# ArcFace: state-of-the-art accuracy (~300 MB), identical to high/gpu profiles.
# Intentionally NOT Facenet512/opencv here — "works in dev" must mean "works in prod".
MODEL_NAME=ArcFace

# ─── Face Detector Backend ────────────────────────────────────────────────────
# retinaface: best single-stage detector available in DeepFace.
#   ✓ Handles angled faces, small faces, groups, partial occlusion
#   ✓ Runs on pure CPU — no GPU required
#   ✗ ~3–8× slower than opencv on CPU → acceptable for dev; set generous timeouts
#
# DO NOT use opencv (Haar Cascade) for dev — it misses ~30–50 % of real-world faces.
DETECTOR_BACKEND=retinaface

# ─── API Workers & Concurrency ────────────────────────────────────────────────
WORKERS=1                   # single worker → easier debugging, no port conflicts

# ─── Async Job Queue ──────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=1
QUEUE_MAX_SIZE=5
QUEUE_JOB_TIMEOUT_SECONDS=600  # retinaface + ArcFace on CPU can take 5–15 s per image;
                                # generous timeout for debugger stepping
JOB_RESULT_TTL_SECONDS=3600    # 1 hour — dev sessions are short

# ─── Upload Limits ────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=20               # allow real photos during dev testing

# ─── Image quality & pre-processing ──────────────────────────────────────────
# Faces below this detector confidence are silently dropped before caching.
# 0.0 = accept all (disabled).  0.70 is a good starting point for real photos.
MIN_FACE_CONFIDENCE=0.70

# Resize images to at most this pixel count on the longest edge before detection.
# Prevents OOM on very high-resolution uploads; speeds up RetinaFace significantly.
# 0 = no resizing.
MAX_IMAGE_PX=1920

# Apply CLAHE (adaptive histogram equalisation) before detection.
# Helps detect faces in backlit / dark / low-contrast images.
# Adds ~50–200 ms CPU overhead per image.
ENABLE_PREPROCESSING=true

# ─── Cache TTLs ───────────────────────────────────────────────────────────────
FACE_TTL_SECONDS=3600        # 1 hour
GROUP_TTL_SECONDS=7200       # 2 hours
PURGE_INTERVAL_SECONDS=300   # 5 min — fast feedback on TTL behaviour

# ─── Host Port ────────────────────────────────────────────────────────────────
# Port exposed on the Docker host (host:container → API_PORT:8000).
# Change this if 8000 is already in use on your machine.
API_PORT=8000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=/app/data/vision_dev.db

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG              # full trace output

# ─── TensorFlow noise suppression ────────────────────────────────────────────
# Suppress C++ level CUDA/cuDNN/cuFFT "factory already registered" errors and
# the "Could not find CUDA drivers" info messages.  These are harmless on a
# CPU-only machine but flood the log on every startup.
# 0=all, 1=filter INFO, 2=filter WARNING, 3=filter ERROR
TF_CPP_MIN_LOG_LEVEL=3
# Disable oneDNN custom ops info banner
TF_ENABLE_ONEDNN_OPTS=0

# ─── Webhook / Callback defaults ─────────────────────────────────────────────
DEFAULT_CALLBACK_URL=http://host.docker.internal:9000/webhook   # local test server
DEFAULT_CALLBACK_AUTH_USER=
DEFAULT_CALLBACK_AUTH_PASS=
CALLBACK_TIMEOUT_SECONDS=30
CALLBACK_MAX_RETRIES=1       # fail fast in dev
